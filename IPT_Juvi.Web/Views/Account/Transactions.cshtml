@model IPT_Juvi.Web.Models.ViewModels.TransactionsViewModel
@{
    ViewData["Title"] = "Transactions";
    ViewData["Nav"] = "Transactions";
    ViewData["TxQuery"] = Model.Query ?? "";
}

<div class="bizzy-shell bizzy-tx">
    <div class="bizzy-card bizzy-tx-card">
        <div class="bizzy-tx-tab">Transactions</div>

        <div class="bizzy-tx-table-wrap">
            <table class="bizzy-tx-table" aria-label="Transactions">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Product</th>
                        <th class="t-date">Date</th>
                        <th class="t-total">Total</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model.Rows)
                {
                    <tr>
                        <td class="t-user">@r.UserName</td>
                        <td class="t-prod">@r.ProductSummary</td>
                        <td class="t-date">@r.Date.ToString("MM/dd/yyyy")</td>
                        <td class="t-total">&#8369; @r.Total.ToString("N2")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
