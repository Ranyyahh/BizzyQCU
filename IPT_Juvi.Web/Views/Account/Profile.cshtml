@model IPT_Juvi.Web.Models.ViewModels.ProfileDashboardViewModel
@{
    ViewData["Title"] = "Profile";
    ViewData["Nav"] = "SiteExact";
}

<div class="bizzy-shell">
    <button class="bizzy-back" type="button" data-bizzy-back aria-label="Back">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 1 0 1.4L10.4 12l4.3 4.3a1 1 0 1 1-1.4 1.4l-5-5a1 1 0 0 1 0-1.4l5-5a1 1 0 0 1 1.4 0Z"/></svg>
    </button>

    <div class="bizzy-card">
        <div class="bizzy-title-row">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 7a3 3 0 0 1 3-3h10a3 3 0 0 1 3 3v10a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3Zm3-1a1 1 0 0 0-1 1v1h14V7a1 1 0 0 0-1-1Zm-1 5v6a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-6Z"/></svg>
            <span>Enterprise Information</span>
        </div>
        <div class="bizzy-hr"></div>

        <div class="bizzy-hero">
            <div class="bizzy-avatar">
                <img src="@(Model.PhotoPath ?? "/img/avatar-default.svg")" alt="Profile Photo" />
            </div>

            <div class="bizzy-kv">
                <div class="k">Enterprise Name</div>
                <div class="v">@Model.EnterpriseName</div>
                <div class="k">Type</div>
                <div class="v">@Model.EnterpriseType</div>
                <div class="k">GCash No.</div>
                <div class="v">@Model.Phone</div>
                <div class="k">Role</div>
                <div class="v">@Model.Role</div>
            </div>

            <div class="bizzy-hero-actions">
                @if (!string.IsNullOrWhiteSpace(Model.PaymentQrPath))
                {
                    <div class="bizzy-hero-qr">
                        <img src="@Model.PaymentQrPath" alt="GCash QR" />
                    </div>
                }
                <a class="bizzy-btn bizzy-btn-outline" asp-controller="Account" asp-action="Settings" aria-label="Edit">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 17.25V21h3.75L17.8 9.95l-3.75-3.75L3 17.25Zm18-11.5a1 1 0 0 0 0-1.4l-1.35-1.35a1 1 0 0 0-1.4 0l-1.06 1.06 3.75 3.75Z"/></svg>
                    Edit
                </a>
            </div>
        </div>

        <div class="bizzy-grid-2">
            <section class="bizzy-panel">
                <div class="bizzy-panel-title">Enterprise Manager</div>
                <div class="bizzy-panel-hr"></div>

                <div class="bizzy-kv" style="grid-template-columns: 120px 1fr;">
                    <div class="k">Name</div>
                    <div class="v">@Model.ManagerName</div>
                    <div class="k">Section</div>
                    <div class="v">@Model.ManagerSection</div>
                    <div class="k">Student ID</div>
                    <div class="v">@Model.ManagerStudentId</div>
                </div>
            </section>

            <section class="bizzy-panel">
                <div class="bizzy-panel-title dark">
                    <span style="display:inline-flex;align-items:center;gap:8px;">
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 20h18v2H3Zm2-3h3V9H5Zm5 0h3V4h-3Zm5 0h3v-7h-3Z"/></svg>
                        Enterprise Stats
                    </span>
                </div>
                <div class="bizzy-panel-hr"></div>

                <div class="bizzy-stats">
                    <div class="bizzy-stat-row">
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm-1 14-4-4 1.4-1.4L11 13.2l5.6-5.6L18 9Z"/></svg>
                        <div class="n">Orders Completed</div>
                        <div class="v">@Model.OrdersCompleted</div>
                    </div>
                    <div class="bizzy-stat-row">
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 8V7l-9-5-9 5v10l9 5 9-5v-1h-2v.8l-7 3.9-7-3.9V8.2l7-3.9 7 3.9V8Z"/></svg>
                        <div class="n">Products Listed</div>
                        <div class="v">@Model.ProductsListed</div>
                    </div>
                    <div class="bizzy-sales">
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1a5 5 0 0 0-5 5c0 2.76 2.24 5 5 5s5-2.24 5-5a5 5 0 0 0-5-5Zm-7 21h14v-2a7 7 0 0 0-14 0Z"/></svg>
                        <div class="n">Total Sales</div>
                        <div class="v">&#8369; @Model.TotalSales.ToString("N2")</div>
                    </div>

                    <div class="bizzy-actions">
                        <a class="bizzy-btn bizzy-btn-outline" asp-controller="Account" asp-action="Transactions">Transaction History</a>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

<form class="bizzy-logout-wrap" asp-controller="Account" asp-action="Logout" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="bizzy-logout-btn" style="border:0;">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 17v-2h4v-6h-4V7l-5 5Zm9-14H9a2 2 0 0 0-2 2v3h2V5h10v14H9v-3H7v3a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2Z"/></svg>
        Log Out
    </button>
</form>
