@model IPT_Juvi.Web.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["Nav"] = "Site";
}

<div class="bizzy-shell">
    <div class="bizzy-card">
        <div class="bizzy-panel-title">Change Password</div>
        <div class="bizzy-panel-hr"></div>

        <form asp-controller="Account" asp-action="ChangePassword" method="post" class="bizzy-panel" style="max-width:520px;margin:0 auto;">
            @Html.AntiForgeryToken()
            <div class="bizzy-form-row" style="grid-template-columns: 170px 1fr;">
                <label asp-for="CurrentPassword">Current Password</label>
                <input class="bizzy-input" asp-for="CurrentPassword" />
            </div>
            <div class="bizzy-form-row" style="grid-template-columns: 170px 1fr;">
                <label asp-for="NewPassword">New Password</label>
                <input class="bizzy-input" asp-for="NewPassword" />
            </div>
            <div class="bizzy-form-row" style="grid-template-columns: 170px 1fr;">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <input class="bizzy-input" asp-for="ConfirmPassword" />
            </div>

            <div class="bizzy-form-actions" style="justify-content:flex-start;">
                <span class="text-danger" style="font-size:12px;font-weight:700;">@Html.ValidationSummary()</span>
            </div>

            <div class="bizzy-form-actions">
                <a class="bizzy-btn bizzy-btn-outline" asp-controller="Account" asp-action="Settings">Cancel</a>
                <button class="bizzy-btn bizzy-btn-primary" type="submit">Update</button>
            </div>
            <div style="margin-top:10px;font-size:12px;font-weight:700;color:rgba(0,0,0,.7);">
                Demo current password: <span style="font-family:Consolas,monospace;">password</span>
            </div>
        </form>
    </div>
</div>

