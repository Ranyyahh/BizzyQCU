@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Enterprise Register</title>

    <style>
            /* ========== ORIGINAL DESKTOP CODE ========== */
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
                font-family: 'Segoe UI';
            }

            body {
                background: url('/images/backgroundpic.png') no-repeat center center/cover;
            }

            .navbar {
                height: 90px;
                display: flex;
                align-items: center;
                padding: 0 40px;
                background: #ffffff;
                z-index: 3;
            }

            .logo img {
                height: 130px;
                display: block;
            }

            .divider {
                width: 3px;
                height: 30px;
                background: #f4c430;
                margin: 0 30px;
            }

            .nav-links {
                display: flex;
                gap: 40px;
            }

                .nav-links a {
                    text-decoration: none;
                    color: #1a2a6c;
                    font-weight: 600;
                }

            .overlay {
                position: absolute;
                top: 90px;
                width: 100%;
                height: calc(100vh - 90px);
                background: linear-gradient( to bottom, rgba(255, 222, 66, 0.35), rgba(255, 222, 66, 0.15), rgba(17, 31, 162, 0.15), rgba(17, 31, 162, 0.35) );
                z-index: 1;
            }

            .container {
                position: relative;
                z-index: 2;
                height: calc(100vh - 90px);
                display: flex;
                justify-content: center;
                align-items: center;
            }

            .login-box {
                width: 440px;
                background: rgba(255,255,255,0.9);
                backdrop-filter: blur(10px);
                padding: 50px 40px;
                border-radius: 25px;
                text-align: center;
                box-shadow: 0 15px 40px rgba(0,0,0,0.25);
            }

            h2 {
                color: #1a2a6c;
                margin-bottom: 20px;
            }

            .input-group input {
                width: 100%;
                padding: 12px 15px;
                border-radius: 25px;
                border: 1px solid #ccc;
                margin-bottom: 12px;
                outline: none;
                transition: 0.2s;
            }

                .input-group input:focus {
                    border-color: #f4c430;
                    box-shadow: 0 0 5px rgba(244,196,48,0.5);
                }

            .login-btn {
                width: 100%;
                padding: 12px;
                border-radius: 25px;
                border: none;
                background: #f4c430;
                font-weight: bold;
                cursor: pointer;
                margin-top: 10px;
                transition: 0.2s;
                position: relative;
            }

                .login-btn:hover:not(:disabled) {
                    background: #e0b52f;
                }

                .login-btn:active:not(:disabled) {
                    transform: scale(0.97);
                }

                .login-btn:disabled {
                    background: #cccccc;
                    cursor: not-allowed;
                    opacity: 0.6;
                }

                .login-btn.loading {
                    pointer-events: none;
                    background: #e0b52f;
                }

                    .login-btn.loading span {
                        visibility: hidden;
                    }

                    .login-btn.loading::after {
                        content: "";
                        width: 20px;
                        height: 20px;
                        border: 3px solid white;
                        border-top: 3px solid transparent;
                        border-radius: 50%;
                        position: absolute;
                        top: 50%;
                        left: 50%;
                        transform: translate(-50%, -50%);
                        animation: spin 0.8s linear infinite;
                    }

            @@keyframes spin {
                to {
                    transform: translate(-50%, -50%) rotate(360deg);
                }
            }

            .upload-link {
                display: block;
                margin: 15px 0;
                color: #1a2a6c;
                text-decoration: underline;
                cursor: pointer;
            }

            .signup {
                margin-top: 15px;
                font-size: 13px;
            }

                .signup a {
                    color: #1a2a6c;
                    font-weight: bold;
                    text-decoration: none;
                }

            .file-name {
                font-size: 11px;
                color: #1a6c3b;
                margin-top: 5px;
            }

            /* ========== MOBILE RESPONSIVE  ========== */
            @@media (max-width: 768px) {
                body {
                    overflow: auto;
                }

                .navbar {
                    height: 70px;
                    padding: 0 15px;
                    background: #ffffff;
                    position: fixed;
                    top: 0;
                    left: 0;
                    right: 0;
                    justify-content: space-between;
                    z-index: 100;
                }

                .logo {
                    position: absolute;
                    left: 50%;
                    transform: translateX(-50%);
                }

                    .logo img {
                        height: 100px;
                    }

                .divider {
                    display: none;
                }

                .nav-links {
                    display: none;
                }

                .fullscreen-menu {
                    position: fixed;
                    top: 0;
                    right: -100%;
                    width: 100%;
                    height: 100vh;
                    background: linear-gradient(135deg, #111fa2, #ffde42);
                    backdrop-filter: blur(10px);
                    display: flex;
                    flex-direction: column;
                    justify-content: center;
                    align-items: center;
                    gap: 20px;
                    transition: right 0.4s ease-in-out;
                    z-index: 98;
                }

                    .fullscreen-menu.active {
                        right: 0;
                    }

                    .fullscreen-menu a {
                        color: white;
                        font-size: 20px;
                        font-weight: 600;
                        text-decoration: none;
                        padding: 10px 0;
                        text-align: center;
                        width: 80%;
                        border-bottom: 1px solid rgba(255,255,255,0.15);
                    }

                        .fullscreen-menu a:last-child {
                            border-bottom: none;
                        }

                .back-btn {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background: #a8d8ea;
                    width: 38px;
                    height: 38px;
                    border-radius: 50%;
                    cursor: pointer;
                    z-index: 99;
                }

                    .back-btn a {
                        color: #1a2a6c;
                        font-size: 24px;
                        font-weight: bold;
                        text-decoration: none;
                        line-height: 1;
                    }

                .hamburger {
                    display: flex;
                    flex-direction: column;
                    cursor: pointer;
                    gap: 5px;
                    z-index: 99;
                    position: relative;
                }

                    .hamburger span {
                        width: 25px;
                        height: 3px;
                        background: #1a2a6c;
                        border-radius: 3px;
                    }

                .menu-overlay {
                    display: none;
                    position: fixed;
                    top: 0;
                    left: 0;
                    right: 0;
                    bottom: 0;
                    background: linear-gradient(135deg, rgba(255,222,66,0.15), rgba(17,31,162,0.3));
                    z-index: 97;
                }

                    .menu-overlay.active {
                        display: block;
                    }

                .overlay {
                    top: 0;
                    height: 100%;
                    position: fixed;
                    z-index: 0;
                }

                .container {
                    height: auto;
                    min-height: 100vh;
                    padding: 100px 20px 40px 20px;
                }

                .login-box {
                    width: 100%;
                    max-width: 400px;
                    padding: 35px 25px;
                }

                h2 {
                    font-size: 22px;
                }

                .input-group input {
                    padding: 10px 14px;
                }
            }

            @@media (min-width: 760px) {
                .hamburger, .back-btn, .fullscreen-menu, .menu-overlay {
                    display: none !important;
                }
            }
    </style>
</head>

<body>

    <div class="navbar">
        <!-- Back button sa LEFT (<) -->
        <div class="back-btn">
            <a href="/">&lt;</a>
        </div>

        <!-- Logo sa GITNA -->
        <div class="logo">
            <img src="/images/bizzyqcu.png">
        </div>

        <div class="divider"></div>

        <!-- Desktop nav links -->
        <div class="nav-links" id="navLinks">
            <a href="#">HOME</a>
            <a href="#">PRODUCTS</a>
            <a href="#">ENTERPRISES</a>
            <a href="#">ABOUT US</a>
        </div>

        <!-- Hamburger menu sa RIGHT -->
        <div class="hamburger" onclick="toggleMenu()">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </div>

    <!-- Full screen menu (para sa mobile) -->
    <div class="fullscreen-menu" id="fullscreenMenu">
        <a href="#">HOME</a>
        <a href="#">PRODUCTS</a>
        <a href="#">ENTERPRISES</a>
        <a href="#">ABOUT US</a>
        <a href="/Account/Login">LOG IN</a>
        <a href="/Account/RegisterCustomer">REGISTER</a>
    </div>

    <!-- Overlay sa likod ng menu -->
    <div class="menu-overlay" id="menuOverlay" onclick="toggleMenu()"></div>

    <div class="overlay"></div>

    <div class="container">
        <div class="login-box">

            <h2>Register (Enterprise)</h2>

            <div class="input-group">
                <input type="text" id="enterpriseName" placeholder="Enterprise Name">
            </div>

            <div class="input-group">
                <input type="text" id="username" placeholder="Username">
            </div>

            <div class="input-group">
                <input type="password" id="password" placeholder="Password">
            </div>

            <div class="input-group">
                <input type="email" id="email" placeholder="Email">
            </div>

            <div class="input-group">
                <input type="text" id="contactEnterprise" placeholder="Contact Number">
            </div>

            <div class="input-group">
                <input type="text" id="enterpriseType" placeholder="Type of Enterprise">
            </div>

            <label class="upload-link" for="docUpload">
                Upload Document
            </label>
            <input type="file" id="docUpload" hidden>
            <div id="fileNameDisplay" class="file-name"></div>

            <button class="login-btn" id="registerBtn" disabled>
                <span>Register</span>
            </button>

            <div class="signup">
                Already have an account? <a href="/Account/Login">Login</a>
            </div>

            <div class="signup">
                Want to Buy? <a href="/Account/RegisterCustomer">Sign Up Here</a>
            </div>

        </div>
    </div>

    <script>
            // Toggle menu function para sa mobile
            function toggleMenu() {
                const fullscreenMenu = document.getElementById("fullscreenMenu");
                const menuOverlay = document.getElementById("menuOverlay");
                fullscreenMenu.classList.toggle("active");
                menuOverlay.classList.toggle("active");
            }

            // Contact number validation (numbers only, max 11 digits)
            const contactEnterprise = document.getElementById("contactEnterprise");
            contactEnterprise.addEventListener("input", function () {
                this.value = this.value.replace(/\D/g, '').slice(0, 11);
                checkAllFields();
            });

            // Get all form elements
            const enterpriseName = document.getElementById("enterpriseName");
            const username = document.getElementById("username");
            const password = document.getElementById("password");
            const email = document.getElementById("email");
            const enterpriseType = document.getElementById("enterpriseType");
            const docUpload = document.getElementById("docUpload");
            const registerBtn = document.getElementById("registerBtn");
            const fileNameSpan = document.getElementById("fileNameDisplay");

            // File upload preview
            docUpload.addEventListener("change", function() {
                if (docUpload.files.length > 0) {
                    let name = docUpload.files[0].name;
                    if (name.length > 30) name = name.substring(0, 27) + "...";
                    fileNameSpan.innerText = "✅ " + name;
                } else {
                    fileNameSpan.innerText = "";
                }
                checkAllFields();
            });

            // Check all fields bago i-enable ang register button
            function checkAllFields() {
                registerBtn.disabled = !(enterpriseName.value.trim() !== "" &&
                    username.value.trim() !== "" &&
                    password.value.trim() !== "" &&
                    email.value.trim() !== "" &&
                    contactEnterprise.value.trim() !== "" &&
                    enterpriseType.value.trim() !== "" &&
                    docUpload.files.length > 0);
            }

            // Add event listeners sa lahat ng fields
            enterpriseName.addEventListener("input", checkAllFields);
            username.addEventListener("input", checkAllFields);
            password.addEventListener("input", checkAllFields);
            email.addEventListener("input", checkAllFields);
            contactEnterprise.addEventListener("input", checkAllFields);
            enterpriseType.addEventListener("input", checkAllFields);

            // Register button click - add loading state
            registerBtn.addEventListener("click", function () {
                if (!registerBtn.disabled) {
                    registerBtn.classList.add("loading");
                }
            });
    </script>

</body>
</html>
