@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-bg">
    <div class="auth-card register-enterprise">
        <h2>Register (Enterprise)</h2>
        @using (Html.BeginForm("RegisterEnterprise", "Account", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            <input type="text" name="EnterpriseName" placeholder="Enterprise Name" required />
            <input type="text" name="Username" placeholder="Username" required />
            <input type="password" name="Password" placeholder="Password" required />
            <input type="email" name="Email" placeholder="Email" required />
            <input type="text" name="ContactNumber" placeholder="Contact Number" required />
            <input type="text" name="Type" placeholder="Type of Enterprise" required />

            <div class="upload-link-wrapper">
                <input type="file" name="Documents" id="docsFile" accept=".pdf,.jpg,.png,.doc,.docx" required style="display: none;" />
                <a href="#" class="upload-text-link" onclick="document.getElementById('docsFile').click(); return false;">Upload Document</a>
                <span class="file-name-display" id="docsFileName">No file chosen</span>
            </div>

            <button type="submit" class="auth-btn">Register</button>
        }
        <div class="auth-links">
            <a href="@Url.Action("Login","Account")">Back to Login</a><br />
            <span>Want to Buy? <a href="@Url.Action("RegisterCustomer","Account")">Sign Up Here</a></span>
        </div>
    </div>
</div>

<script>
    document.getElementById('docsFile').addEventListener('change', function (e) {
        var fileName = e.target.files.length > 0 ? e.target.files[0].name : 'No file chosen';
        document.getElementById('docsFileName').innerText = fileName;
    });
</script>
