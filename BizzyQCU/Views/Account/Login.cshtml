@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>BizzyQCU - Login</title>

    <style>
            /* ========== ORIGINAL DESKTOP CODE ========== */
            html, body {
                margin: 0;
                padding: 0;
                height: 100%;
                font-family: 'Segoe UI', sans-serif;
            }

            * {
                box-sizing: border-box;
            }

            body {
                background: url('/images/backgroundpic.png') no-repeat center center/cover;
                overflow: hidden;
            }

            .navbar {
                height: 90px;
                display: flex;
                align-items: center;
                padding: 0 40px;
                background: #ffffff;
                z-index: 3;
            }

            .logo img {
                height: 130px;
                display: block;
            }

            .divider {
                width: 3px;
                height: 30px;
                background: #f4c430;
                margin: 0 30px;
            }

            .nav-links {
                display: flex;
                gap: 40px;
            }

                .nav-links a {
                    text-decoration: none;
                    color: #1a2a6c;
                    font-weight: 600;
                }

            .overlay {
                position: absolute;
                top: 90px;
                width: 100%;
                height: calc(100vh - 90px);
                background: linear-gradient( to bottom, rgba(255, 222, 66, 0.35), rgba(255, 222, 66, 0.15), rgba(17, 31, 162, 0.15), rgba(17, 31, 162, 0.35) );
                z-index: 1;
            }

            .container {
                position: relative;
                z-index: 2;
                height: calc(100vh - 90px);
                display: flex;
                justify-content: center;
                align-items: center;
            }

            .login-box {
                width: 430px;
                background: rgba(255, 255, 255, 0.9);
                backdrop-filter: blur(10px);
                padding: 55px 40px;
                border-radius: 25px;
                text-align: center;
                box-shadow: 0 15px 40px rgba(0,0,0,0.25);
            }

                .login-box h2 {
                    color: #1a2a6c;
                    margin-bottom: 25px;
                    font-size: 28px;
                }

            .input-group {
                margin-bottom: 18px;
            }

                .input-group input {
                    width: 100%;
                    padding: 14px 16px;
                    border-radius: 25px;
                    border: 1px solid #ccc;
                    outline: none;
                    font-size: 14px;
                    transition: 0.2s;
                }

                    .input-group input:focus {
                        border-color: #f4c430;
                        box-shadow: 0 0 5px rgba(244,196,48,0.5);
                    }

            .login-btn {
                width: 100%;
                padding: 14px;
                border-radius: 25px;
                border: none;
                background: #f4c430;
                font-weight: bold;
                cursor: pointer;
                margin-top: 10px;
                transition: all 0.2s ease;
                position: relative;
            }

                .login-btn:hover:not(:disabled) {
                    background: #e0b52f;
                    transform: scale(1.03);
                    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
                }

                .login-btn:active:not(:disabled) {
                    transform: scale(0.98);
                }

                .login-btn:disabled {
                    background: #cccccc;
                    cursor: not-allowed;
                    opacity: 0.6;
                }

                .login-btn.loading {
                    pointer-events: none;
                    background: #e0b52f;
                }

                    .login-btn.loading span {
                        visibility: hidden;
                    }

                    .login-btn.loading::after {
                        content: "";
                        width: 20px;
                        height: 20px;
                        border: 3px solid white;
                        border-top: 3px solid transparent;
                        border-radius: 50%;
                        position: absolute;
                        top: 50%;
                        left: 50%;
                        transform: translate(-50%, -50%);
                        animation: spin 0.8s linear infinite;
                    }

            @@keyframes spin {
                to {
                    transform: translate(-50%, -50%) rotate(360deg);
                }
            }

            .forgot {
                display: block;
                margin-top: 10px;
                font-size: 12px;
                color: #1a2a6c;
                text-decoration: none;
            }

            .signup {
                margin-top: 20px;
                font-size: 12px;
                color: #1a2a6c;
            }

                .signup a {
                    color: #1a2a6c;
                    font-weight: bold;
                    text-decoration: none;
                }

            /* ========== MOBILE RESPONSIVE ========== */
            @@media (max-width: 768px) {
                body {
                    overflow: auto;
                }

                .navbar {
                    height: 70px;
                    padding: 0 15px;
                    background: #ffffff;
                    position: fixed;
                    top: 0;
                    left: 0;
                    right: 0;
                    justify-content: space-between;
                    z-index: 100;
                }

                .logo {
                    position: absolute;
                    left: 50%;
                    transform: translateX(-50%);
                }

                    .logo img {
                        height: 100px;
                    }

                .divider {
                    display: none;
                }

                .nav-links {
                    display: none;
                }

                .fullscreen-menu {
                    position: fixed;
                    top: 0;
                    right: -100%;
                    width: 100%;
                    height: 100vh;
                    background: linear-gradient(135deg, rgba(26, 42, 108, 0.95), rgba(26, 42, 108, 0.9));
                    backdrop-filter: blur(10px);
                    display: flex;
                    flex-direction: column;
                    justify-content: center;
                    align-items: center;
                    gap: 20px;
                    transition: right 0.4s ease-in-out;
                    z-index: 98;
                }

                    .fullscreen-menu.active {
                        right: 0;
                    }

                    .fullscreen-menu a {
                        color: white;
                        font-size: 20px;
                        font-weight: 600;
                        text-decoration: none;
                        padding: 10px 0;
                        text-align: center;
                        width: 80%;
                        border-bottom: 1px solid rgba(255,255,255,0.15);
                    }

                        .fullscreen-menu a:last-child {
                            border-bottom: none;
                        }
                /* Back button - Baby blue */
                .back-btn {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background: #a8d8ea;
                    width: 38px;
                    height: 38px;
                    border-radius: 50%;
                    cursor: pointer;
                    z-index: 99;
                }

                    .back-btn a {
                        color: #1a2a6c;
                        font-size: 24px;
                        font-weight: bold;
                        text-decoration: none;
                        line-height: 1;
                    }

                .hamburger {
                    display: flex;
                    flex-direction: column;
                    cursor: pointer;
                    gap: 5px;
                    z-index: 99;
                    position: relative;
                }

                    .hamburger span {
                        width: 25px;
                        height: 3px;
                        background: #1a2a6c;
                        border-radius: 3px;
                    }

                .menu-overlay {
                    display: none;
                    position: fixed;
                    top: 0;
                    left: 0;
                    right: 0;
                    bottom: 0;
                    background: linear-gradient(135deg, rgba(255,222,66,0.15), rgba(17,31,162,0.3));
                    z-index: 97;
                }

                    .menu-overlay.active {
                        display: block;
                    }

                .overlay {
                    top: 0;
                    height: 100%;
                    position: fixed;
                    z-index: 0;
                }

                .container {
                    height: auto;
                    min-height: 100vh;
                    padding: 100px 20px 40px 20px;
                }

                .login-box {
                    width: 100%;
                    max-width: 400px;
                    padding: 35px 25px;
                }

                    .login-box h2 {
                        font-size: 24px;
                        margin-bottom: 20px;
                    }

                .input-group input {
                    padding: 12px 16px;
                }

                .login-btn {
                    padding: 12px;
                }
            }

            @@media (min-width: 760px) {
                .hamburger, .back-btn, .fullscreen-menu, .menu-overlay {
                    display: none !important;
                }
            }
    </style>
</head>

<body>

    <div class="navbar">
        <div class="back-btn">
            <a href="/">&lt;</a>
        </div>

        <div class="logo">
            <img src="/images/bizzyqcu.png" alt="logo">
        </div>

        <div class="divider"></div>

        <div class="nav-links" id="navLinks">
            <a href="#">HOME</a>
            <a href="#">PRODUCTS</a>
            <a href="#">ENTERPRISES</a>
            <a href="#">ABOUT US</a>
        </div>

        <div class="hamburger" onclick="toggleMenu()">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </div>

    <div class="fullscreen-menu" id="fullscreenMenu">
        <a href="#">HOME</a>
        <a href="#">PRODUCTS</a>
        <a href="#">ENTERPRISES</a>
        <a href="#">ABOUT US</a>
        <a href="/Account/Login">LOG IN</a>
        <a href="/Account/RegisterCustomer">REGISTER</a>
    </div>

    <div class="menu-overlay" id="menuOverlay" onclick="toggleMenu()"></div>
    <div class="overlay"></div>

    <div class="container">
        <div class="login-box">
            <h2>Login</h2>

            <form id="loginForm" action="/Account/Login" method="post">
                <div class="input-group">
                    <input type="text" id="username" name="username" placeholder="Username" required>
                </div>

                <div class="input-group">
                    <input type="password" id="password" name="password" placeholder="Password" required>
                </div>

                <button class="login-btn" id="loginBtn" disabled>
                    <span>Login</span>
                </button>
            </form>

            <a href="#" class="forgot">Forgot Password?</a>

            <div class="signup">
                New to BizzyQCU? <a href="/Account/RegisterCustomer">Sign Up</a>
            </div>
        </div>
    </div>

    <script>
            function toggleMenu() {
                const fullscreenMenu = document.getElementById("fullscreenMenu");
                const menuOverlay = document.getElementById("menuOverlay");
                fullscreenMenu.classList.toggle("active");
                menuOverlay.classList.toggle("active");
            }

            const usernameInput = document.getElementById("username");
            const passwordInput = document.getElementById("password");
            const loginBtn = document.getElementById("loginBtn");
            const form = document.getElementById("loginForm");

            function checkFields() {
                loginBtn.disabled = !(usernameInput.value.trim() !== "" && passwordInput.value.trim() !== "");
            }

            usernameInput.addEventListener("input", checkFields);
            passwordInput.addEventListener("input", checkFields);

            form.addEventListener("submit", function (e) {
                if (loginBtn.disabled) {
                    e.preventDefault();
                    return false;
                }
                loginBtn.classList.add("loading");
            });
    </script>

</body>
</html>