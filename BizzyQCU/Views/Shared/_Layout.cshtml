<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <title>@ViewBag.Title - BizzyQCU</title>
    <link href="~/Content/Style.css" rel="stylesheet" />
</head>
<body>

    <nav class="main-navbar">
        <div class="nav-container">

            <!-- DESKTOP NAV -->
            <div class="nav-left">
                <img src="~/images/logo.png" alt="BizzyQCU" class="logo" />
                <div class="nav-divider"></div>
            </div>

            <div class="nav-links">
                <a href="#">HOME</a>
                <a href="#">PRODUCTS</a>
                <a href="#">ENTERPRISES</a>
                <a href="#">ABOUT US</a>
            </div>

            <!-- MOBILE UI -->
            <button class="back-btn" onclick="history.back()">&#8592;</button>

            <div class="nav-center">
                <img src="~/images/logo.png" class="logo" />
            </div>

            <div class="hamburger" onclick="toggleMenu()">☰</div>

        </div>
    </nav>

    <!-- MOBILE MENU na may close button -->
    <div class="mobile-menu" id="mobileMenu">
        <button class="close-menu" onclick="toggleMenu()">&times;</button>
        <h2>BizzyQCU</h2>
        <a href="#" onclick="toggleMenu()">HOME</a>
        <a href="#" onclick="toggleMenu()">PRODUCTS</a>
        <a href="#" onclick="toggleMenu()">ENTERPRISES</a>
        <a href="#" onclick="toggleMenu()">ABOUT US</a>
        <a href="#" onclick="toggleMenu()">LOG IN</a>
        <a href="#" onclick="toggleMenu()">REGISTER</a>
    </div>

    @RenderBody()

    <script>
        function toggleMenu() {
            var menu = document.getElementById("mobileMenu");
            menu.classList.toggle("active");

            // Para hindi mag-scroll ang body kapag bukas ang menu
            if (menu.classList.contains("active")) {
                document.body.style.overflow = "hidden";
            } else {
                document.body.style.overflow = "";
            }
        }

        // Close menu kapag nag-click sa labas
        document.addEventListener('click', function (event) {
            var menu = document.getElementById("mobileMenu");
            var hamburger = document.querySelector('.hamburger');

            if (menu.classList.contains('active') &&
                !menu.contains(event.target) &&
                !hamburger.contains(event.target)) {
                menu.classList.remove('active');
                document.body.style.overflow = "";
            }
        });

        // Close menu kapag nag-resize sa desktop
        window.addEventListener('resize', function () {
            if (window.innerWidth > 768) {
                var menu = document.getElementById("mobileMenu");
                menu.classList.remove("active");
                document.body.style.overflow = "";
            }
        });

        // Close menu kapag pinindot ang back button ng browser
        window.addEventListener('popstate', function () {
            var menu = document.getElementById("mobileMenu");
            if (menu.classList.contains("active")) {
                menu.classList.remove("active");
                document.body.style.overflow = "";
            }
        });
    </script>

</body>
</html>
